---
layout: default
---
<article
  {% if page.feature-img or page.color %}class="show-banner feature-image" data-show="{{ page.permalink | replace: '/', '' | strip }}"{% else %}class="show-banner" data-show="{{ page.permalink | replace: '/', '' | strip }}"{% endif %}
>
  <header
    id="main"
    class="iyf-hero iyf-hero--dim"
    {% if page.feature-img %}style="background-image: url('{{ page.feature-img | relative_url }}');"{% elsif page.color %}style="background-color: {{ page.color }}; background-image: url('{{ site.color_image | relative_url }}');"{% endif %}
  >
    {% unless page.hide_title %}
      {% if page.next_event_date %}
        <p class="iyf-hero__eyebrow">{{ page.next_event_date | date: "%a · %e %b" }}{% if page.venue %} · {{ page.venue }}{% endif %}</p>
      {% endif %}
      {%- comment -%}
        Show titles often pack SEO metadata after a separator. Two are in
        the wild: bullet ('•') and dashed-with-spaces (' - '). Examples:
          "Comedy Brew • English Stand-Up Comedy Open Mic • EVERY Thursday at ROBINS …"
          "Random Facts Exchange - the Science Comedy Show in Zürich"
        Normalize ' - ' to ' • ' before splitting so both surfaces (hero
        below, event card on the home grid) share one split contract. The
        space-padding on the dash is deliberate — never replace bare '-'
        because inner hyphens (e.g. "Stand-Up", "Stand-up") are part of
        normal words.
        First segment is the show name (the h1). The rest collapses into a
        subtitle only when page.tagline isn't already providing one.
      {%- endcomment -%}
      {%- assign title_normalized = page.title | replace: ' - ', ' • ' -%}
      {%- assign title_parts = title_normalized | split: '•' -%}
      {%- assign primary_title = title_parts[0] | strip -%}
      <h1 id="{{ page.title | cgi_escape }}" class="iyf-hero__title">{{ primary_title }}</h1>
      {% if page.tagline %}
        <p class="iyf-hero__subtitle">{{ page.tagline }}</p>
      {% elsif title_parts.size > 1 %}
        {%- assign rest_segments = title_parts | slice: 1, 99 -%}
        {%- assign secondary_title = rest_segments | join: ' · ' | strip -%}
        <p class="iyf-hero__subtitle">{{ secondary_title }}</p>
      {% endif %}
      {% if page.ticket_url %}
        <div class="iyf-hero__actions">
          <a class="btn-ticket btn-ticket--xl" href="{{ page.ticket_url }}" rel="noopener" target="_blank">Get Tickets</a>
        </div>
      {% endif %}
    {% endunless %}
  </header>

  <section class="post-content">
    {% if page.bootstrap %}
      <div class="bootstrap-iso">
    {% endif %}
    {{ content }}
    {% if page.ticket_url %}
      <p class="iyf-show-cta"><a href="{{ page.ticket_url }}" class="btn-ticket btn-ticket--xl" rel="noopener" target="_blank">Get Tickets</a></p>
    {% endif %}

    {%- comment -%}
      Regular performers / hosts — placed at the BOTTOM, below the ticket CTA, so
      the show (and getting people out) stays the focus. Sits INSIDE .post-content
      so it inherits the show page's centred, padded column instead of spanning
      full width. Sourced from the show's `hosts:` slug-list (stable hosts/
      residents, NOT per-night lineups); each slug resolves against site.comedians
      and an unknown slug renders nothing (never a broken link). `hosts_label`
      overrides the default "Hosted by" (e.g. "Featuring" for the Brexiles
      ensemble, "Usually hosted by" for Comedy Brew's two rotating hosts).
    {%- endcomment -%}
    {%- if page.hosts and page.hosts.size > 0 -%}
      {%- assign host_pages = '' | split: '' -%}
      {%- for slug in page.hosts -%}
        {%- assign match = site.comedians | where: "slug", slug | first -%}
        {%- if match -%}{%- assign host_pages = host_pages | push: match -%}{%- endif -%}
      {%- endfor -%}
      {%- if host_pages.size > 0 -%}
        <section class="iyf-show-hosts" aria-label="Regular performers at this show">
          <h2 class="iyf-show-hosts__title">{{ page.hosts_label | default: 'Hosted by' }}</h2>
          <ul class="iyf-show-hosts__grid" role="list">
            {%- for c in host_pages -%}
              <li data-slug="{{ c.slug }}">
                <a class="iyf-comedian-card" href="{{ c.url | relative_url }}">
                  {%- if c.photo -%}
                    <div class="iyf-comedian-card__media">
                      <img src="{{ c.photo | relative_url }}" alt="{{ c.title }}" loading="lazy" />
                    </div>
                  {%- else -%}
                    <div class="iyf-comedian-card__media iyf-comedian-card__media--placeholder" aria-hidden="true"></div>
                  {%- endif -%}
                  <span class="iyf-comedian-card__name">{{ c.title }}</span>
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </section>
      {%- endif -%}
    {%- endif -%}
    {% if page.bootstrap %}
      </div>
    {% endif %}
  </section>

</article>

<!-- Post navigation -->
{% if site.post_navigation  or site.theme_settings.post_navigation %}
  {% include blog/post_nav.liquid %}
{% endif %}

{% if page.color %}
<style>
  /* page.color tinting kept for posts that override link/share/footer accent. */
  .post-content a,
  .share-buttons a,
  .tag-list a:not(:hover),
  div#post-nav a,
  footer a {
    color: {{ page.color }} !important;
  }
  .site-header nav a:hover {
    color: {{ page.color }} !important;
  }
  a.button:hover {
    background: {{ page.color }} !important;
    border: 1px solid {{ page.color }} !important;
    color: white;
    text-decoration: none;
    filter: none;
  }
</style>
{% endif %}
