---
layout: default
---

{%- assign socials = '' | split: '' -%}
{%- if page.instagram and page.instagram != ''     -%}{%- assign socials = socials | push: 'instagram'     -%}{%- endif -%}
{%- if page.tiktok and page.tiktok != ''           -%}{%- assign socials = socials | push: 'tiktok'        -%}{%- endif -%}
{%- if page.facebook_page and page.facebook_page != '' -%}{%- assign socials = socials | push: 'facebook' -%}{%- endif -%}
{%- if page.x and page.x != ''                     -%}{%- assign socials = socials | push: 'x'            -%}{%- endif -%}
{%- if page.youtube_channel and page.youtube_channel != '' -%}{%- assign socials = socials | push: 'youtube' -%}{%- endif -%}
{%- if page.website and page.website != ''         -%}{%- assign socials = socials | push: 'website'       -%}{%- endif -%}

<article class="iyf-comedian-profile">
  <header class="iyf-comedian-profile__header">
    {% if page.photo %}
      <div class="iyf-comedian-profile__media">
        <img src="{{ page.photo | relative_url }}"
             alt="{{ page.title }}"
             loading="lazy" />
      </div>
    {% endif %}
    <div class="iyf-comedian-profile__heading">
      <h1 class="iyf-comedian-profile__name">{{ page.title }}</h1>
      {%- comment -%}
        Crawlable relevance sub-line. Puts "Stand-Up Comedian" + "Zürich" in
        visible body text next to the name, so a "<name> comedian" query has
        on-page support beyond the JSON-LD. Not a keyword meta (dead signal) —
        real text that reads naturally.
      {%- endcomment -%}
      <p class="iyf-comedian-profile__role">Stand-Up Comedian · IN YOUR FACE Comedy, Zürich</p>
    </div>
  </header>

  {% if page.bio and page.bio != '' %}
    <section class="iyf-comedian-profile__bio">
      {{ page.bio | markdownify }}
    </section>
  {% endif %}

  {% if socials.size > 0 %}
    <nav class="iyf-comedian-profile__socials" aria-label="{{ page.title }} on social media">
      {% if page.instagram and page.instagram != '' %}
        <a class="iyf-social-link iyf-social-link--instagram"
           href="{{ page.instagram }}" target="_blank" rel="noopener"
           aria-label="{{ page.title }} on Instagram">
          <i class="fab fa-instagram" aria-hidden="true"></i><span>Instagram</span>
        </a>
      {% endif %}
      {% if page.tiktok and page.tiktok != '' %}
        <a class="iyf-social-link iyf-social-link--tiktok"
           href="{{ page.tiktok }}" target="_blank" rel="noopener"
           aria-label="{{ page.title }} on TikTok">
          <i class="fab fa-tiktok" aria-hidden="true"></i><span>TikTok</span>
        </a>
      {% endif %}
      {% if page.facebook_page and page.facebook_page != '' %}
        <a class="iyf-social-link iyf-social-link--facebook"
           href="{{ page.facebook_page }}" target="_blank" rel="noopener"
           aria-label="{{ page.title }} on Facebook">
          <i class="fab fa-facebook" aria-hidden="true"></i><span>Facebook</span>
        </a>
      {% endif %}
      {% if page.x and page.x != '' %}
        <a class="iyf-social-link iyf-social-link--x"
           href="{{ page.x }}" target="_blank" rel="noopener"
           aria-label="{{ page.title }} on X">
          <i class="fab fa-x-twitter" aria-hidden="true"></i><span>X</span>
        </a>
      {% endif %}
      {% if page.youtube_channel and page.youtube_channel != '' %}
        <a class="iyf-social-link iyf-social-link--youtube"
           href="{{ page.youtube_channel }}" target="_blank" rel="noopener"
           aria-label="{{ page.title }} on YouTube">
          <i class="fab fa-youtube" aria-hidden="true"></i><span>YouTube</span>
        </a>
      {% endif %}
      {% if page.website and page.website != '' %}
        <a class="iyf-social-link iyf-social-link--website"
           href="{{ page.website }}" target="_blank" rel="noopener"
           aria-label="{{ page.title }}'s website">
          <i class="fas fa-globe" aria-hidden="true"></i><span>Website</span>
        </a>
      {% endif %}
    </nav>
  {% endif %}

  {%- comment -%}
    Reverse link: shows this comedian is a regular/host at. Sourced from each
    show post's `hosts:` slug-list (stable: hosts/residents, not per-night
    lineups). This injects UNIQUE, substantive content into otherwise-thin
    profiles — the strongest lever against "Crawled – currently not indexed" —
    and completes the bidirectional show↔comedian internal-link graph. A
    comedian who hosts nothing renders no section (no empty heading).
  {%- endcomment -%}
  {%- assign my_shows = site.posts | where_exp: "p", "p.ticket_url" | where_exp: "p", "p.hosts contains page.slug" -%}
  {%- if my_shows.size > 0 -%}
    <section class="iyf-comedian-profile__shows" aria-label="Shows {{ page.title }} performs at">
      <h2 class="iyf-lineup-section__title">Catch {{ page.title | split: ' ' | first }} at</h2>
      <div class="iyf-comedian-profile__show-links">
        {%- for s in my_shows -%}
          {%- assign show_title = s.title | replace: ' - ', ' • ' | split: '•' | first | strip -%}
          <a class="btn-ghost" href="{{ s.url | relative_url }}">{{ show_title }}</a>
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%}
    Photos of this comedian on stage, pulled from the /moments/ gallery. The link
    lives in _data/gallery.yml (each image's `comedian:` slug, set by
    `script/build-gallery-data.rb tag`), never in the Grist-generated
    _comedians/*.md. Unique, on-topic imagery + alt text for an otherwise thin
    profile, and another internal link into the gallery.
  {%- endcomment -%}
  {%- assign my_photos = site.data.gallery | where: "comedian", page.slug -%}
  {%- if my_photos.size > 0 -%}
    <section class="iyf-comedian-profile__photos" aria-label="Photos of {{ page.title }} on stage at IN YOUR FACE Comedy">
      <h2 class="iyf-lineup-section__title">{{ page.title | split: ' ' | first }} on stage</h2>
      <div class="iyf-moments__grid">
        {%- comment -%}
          Deep-link each photo to its exact frame on the Moments timeline. The
          fragment MUST match the figure id minted in _includes/gallery.html:
          `m-` + the slugified filename (whole basename, no split on ".").
        {%- endcomment -%}
        {%- for img in my_photos -%}
          {%- assign moment_anchor = img.src | split: '/' | last | slugify -%}
          <figure class="iyf-moment">
            <a href="{{ '/moments/' | relative_url }}#m-{{ moment_anchor }}">
              <img src="{{ img.src | relative_url }}"
                   alt="{{ page.title }} performing stand-up at IN YOUR FACE Comedy in Zürich"
                   loading="lazy" decoding="async">
            </a>
          </figure>
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

  <p class="iyf-comedian-profile__back">
    <a class="clear" href="{{ '/comedians/' | relative_url }}">&larr; All comedians</a>
  </p>
</article>
