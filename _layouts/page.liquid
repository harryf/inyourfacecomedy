---
layout: default
---

<article {% if page.feature-img %}class="feature-image"{% endif %}>

  <header
    id="main"
    class="iyf-hero iyf-hero--compact"
    {% if page.feature-img %}style="background-image: url('{{ page.feature-img | relative_url }}');"{% endif %}
  >
    {% unless page.hide_title %}
      {% if page.title_override %}
        <h1 id="{{ page.title_override | default: '' | cgi_escape }}" class="iyf-hero__title">{{ page.title_override }}</h1>
        {% if page.subtitle %}
          <p class="iyf-hero__subtitle">{{ page.subtitle }}</p>
        {% endif %}
      {% else %}
        <h1 id="{{ page.title | default: '' | cgi_escape }}" class="iyf-hero__title">{{ page.title }}</h1>
        {% if page.subtitle %}
          <p class="iyf-hero__subtitle">{{ page.subtitle }}</p>
        {% endif %}
      {% endif %}
    {% endunless %}
  </header>

  <section class="post-content">
  {% if page.bootstrap %}
  <div class="bootstrap-iso">
  {% endif %}
	{{ content }}
  {% if page.bootstrap %}
  </div>
  {% endif %}
  </section>

</article>
