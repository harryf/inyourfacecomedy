# Local secrets for script/refresh-next-event-dates.rb
# Copy to `.env` (which is gitignored) and fill in the URL.
# The Ruby script loads this file automatically at startup.

# Healthchecks.io ping URL — dead man's switch + failure routing.
# 1. Create a free account at https://healthchecks.io
# 2. Add a Check with period = 1 day, grace = 1 day
# 3. Paste the ping URL here (looks like https://hc-ping.com/UUID)
# 4. In the check's Integrations tab, connect Telegram (or email/Slack/etc).
#    In the integration settings, ensure "Notify when check goes down" is ON
#    and "Notify when check comes back up" is OFF — otherwise you get noisy
#    success messages alongside the real alerts.
HEALTHCHECKS_URL=
